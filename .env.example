# Packy OpenAI-compatible base URL
PACKY_BASE_URL=https://www.packyapi.com/v1

# GPT chat / script model (Chat 分组令牌)
PACKY_CHAT_API_KEY=your_chat_group_key
PACKY_CHAT_MODEL=gpt-5.2

# gpt-image-2 (Sora 分组令牌)
PACKY_SORA_API_KEY=your_sora_group_key
PACKY_IMAGE_MODEL=gpt-image-2

# RunningHub AI App video workflow
RUNNINGHUB_API_KEY=your_runninghub_key
RUNNINGHUB_SUBMIT_URL=https://www.runninghub.cn/openapi/v2/run/ai-app/2037453629342355457
RUNNINGHUB_QUERY_URL=https://www.runninghub.cn/openapi/v2/query
RUNNINGHUB_UPLOAD_URL=https://www.runninghub.cn/openapi/v2/media/upload/binary
